---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="投稿">
  <Header />
  <main class="submit-page">
    <div class="container">
      <div class="submit-hero">
        <h1 class="submit-title">📝 投稿分享你的经验</h1>
        <p class="submit-subtitle">每一篇经验都可能帮助一位迷茫的学弟学妹做出关键决定</p>
      </div>

      <div class="submit-actions">
        <a href="/admin" class="btn btn-primary btn-lg">
          ✏️ 立即在线投稿
        </a>
        <span class="submit-hint">需要 GitHub 账号登录</span>
      </div>

      <div class="workflow">
        <h2 class="workflow-title">投稿流程</h2>
        <div class="steps">
          <div class="step">
            <div class="step-num">1</div>
            <div class="step-body">
              <h3>点击上方「立即在线投稿」按钮</h3>
              <p>使用 GitHub 账号登录内容管理系统（Decap CMS）</p>
            </div>
          </div>
          <div class="step-arrow">↓</div>
          <div class="step">
            <div class="step-num">2</div>
            <div class="step-body">
              <h3>填写文章信息</h3>
              <p>输入标题、选择分类（转专业/保研/考研/出国留学/就业/其他）、添加标签、写摘要</p>
            </div>
          </div>
          <div class="step-arrow">↓</div>
          <div class="step">
            <div class="step-num">3</div>
            <div class="step-body">
              <h3>用 Markdown 编写正文</h3>
              <p>支持标题、列表、代码块、表格、引用等完整 Markdown 语法，实时预览效果</p>
            </div>
          </div>
          <div class="step-arrow">↓</div>
          <div class="step">
            <div class="step-num">4</div>
            <div class="step-body">
              <h3>发布并自动上线</h3>
              <p>提交后文章将自动部署到站点，通常几分钟内即可在首页看到</p>
            </div>
          </div>
        </div>
      </div>

      <div class="guidelines">
        <h2 class="workflow-title">写作建议</h2>
        <ul class="guide-list">
          <li><strong>真实第一</strong>——只分享自己亲身经历的内容，拒绝虚构和夸大</li>
          <li><strong>结构清晰</strong>——用小标题分段，方便读者快速定位信息</li>
          <li><strong>数据说话</strong>——提到具体数字（绩点、分数、时间线）比笼统描述更有参考价值</li>
          <li><strong>坦诚不足</strong>——走过的弯路和踩过的坑往往比成功经验更有价值</li>
          <li><strong>面向读者</strong>——想象读者和你一年前一样迷茫，你会希望看到什么样的文章？</li>
        </ul>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .submit-page {
    padding: 48px 0 64px;
    min-height: 60vh;
  }

  .submit-hero {
    text-align: center;
    margin-bottom: 40px;
  }

  .submit-title {
    font-size: 32px;
    font-weight: 700;
    line-height: 1.3;
    color: var(--text-primary);
    margin-bottom: 12px;
  }

  .submit-subtitle {
    font-size: 16px;
    color: var(--text-secondary);
  }

  .submit-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin-bottom: 56px;
    padding: 32px;
    background-color: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .btn-lg {
    padding: 14px 36px;
    font-size: 16px;
    font-weight: 600;
    border-radius: var(--radius-md);
  }

  .submit-hint {
    font-size: 13px;
    color: var(--text-muted);
  }

  .workflow {
    margin-bottom: 48px;
  }

  .workflow-title {
    font-size: 22px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 24px;
  }

  .steps {
    max-width: 560px;
    margin: 0 auto;
  }

  .step {
    display: flex;
    gap: 20px;
    align-items: flex-start;
  }

  .step-num {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    background-color: var(--accent);
    border-radius: 50%;
    flex-shrink: 0;
  }

  .step-body h3 {
    font-size: 16px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 4px;
  }

  .step-body p {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .step-arrow {
    text-align: center;
    color: var(--text-muted);
    font-size: 20px;
    margin: 8px 0 8px 60px;
  }

  .guidelines {
    max-width: 640px;
    margin: 0 auto;
    padding: 28px 32px;
    background-color: var(--accent-light);
    border-radius: var(--radius-lg);
  }

  .guide-list {
    list-style: none;
    padding: 0;
  }

  .guide-list li {
    padding: 10px 0;
    font-size: 15px;
    line-height: 1.65;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border);
  }

  .guide-list li:last-child {
    border-bottom: none;
  }

  .guide-list strong {
    color: var(--text-primary);
  }
</style>

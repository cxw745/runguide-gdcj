<section class="hero">
  <div class="hero-bg-glow"></div>
  <div class="container">
    <div class="hero-center">
      <div class="hero-badge">🎓 广财学子自己的飞跃手册</div>
      <h1 class="hero-title">减少信息差<br />让每一步都更清晰</h1>
      <p class="hero-desc">
        由广东财经大学学生自发维护的真实经验分享平台。<br />
        转专业、保研、考研、出国留学——学长学姐走过的路，就是你的参考。
      </p>
      <div class="hero-actions">
        <a href="/articles" class="btn btn-primary">开始阅读</a>
        <a href="#categories" class="btn btn-secondary">浏览分类</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <span class="hero-stat-num">10万+</span>
          <span class="hero-stat-label">累计阅读</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">50+</span>
          <span class="hero-stat-label">真实经验</span>
        </div>
        <div class="hero-stat-divider"></div>
        <div class="hero-stat">
          <span class="hero-stat-num">6</span>
          <span class="hero-stat-label">覆盖方向</span>
        </div>
      </div>
    </div>

    <div class="hero-orbit" id="hero-orbit">
      <div class="orbit-ring" id="orbit-ring">
        <div class="hero-card glass-card hero-card-1" data-orbit="0">
          <span class="hero-card-emoji">📚</span>
          <span class="hero-card-text">考研上岸经验</span>
        </div>
        <div class="hero-card glass-card hero-card-2" data-orbit="1">
          <span class="hero-card-emoji">✈️</span>
          <span class="hero-card-text">留学申请攻略</span>
        </div>
        <div class="hero-card glass-card hero-card-3" data-orbit="2">
          <span class="hero-card-emoji">🎓</span>
          <span class="hero-card-text">保研推免指南</span>
        </div>
        <div class="hero-card glass-card hero-card-4" data-orbit="3">
          <span class="hero-card-emoji">🔄</span>
          <span class="hero-card-text">转专业实录</span>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var orbit = document.getElementById('hero-orbit');
    var ring = document.getElementById('orbit-ring');
    if (!orbit || !ring) return;

    var isHovering = false;
    var angle = 0;
    var rafId = null;

    function positionCards(offset) {
      var cards = ring.querySelectorAll('.hero-card');
      var radius = Math.min(orbit.offsetWidth * 0.38, 220);
      var rect = orbit.getBoundingClientRect();

      cards.forEach(function(card) {
        var idx = parseInt(card.getAttribute('data-orbit') || '0', 10);
        var a = (idx * 90 + offset) * (Math.PI / 180);
        var x = Math.cos(a) * radius;
        var y = Math.sin(a) * radius;

        card.style.left = '50%';
        card.style.top = '50%';
        card.style.transform =
          'translate(-50%, -50%) translate(' + x + 'px, ' + y + 'px)';
      });
    }

    function animate() {
      if (isHovering) {
        angle += 0.8;
      } else {
        angle += 0.15;
      }
      positionCards(angle);
      rafId = requestAnimationFrame(animate);
    }

    orbit.addEventListener('mouseenter', function() {
      isHovering = true;
      ring.classList.add('spinning');
    });

    orbit.addEventListener('mouseleave', function() {
      isHovering = false;
      ring.classList.remove('spinning');
    });

    var resizeObserver = new ResizeObserver(function() {
      positionCards(angle);
    });
    resizeObserver.observe(orbit);

    positionCards(angle);
    animate();
  });
</script>

<style>
  .hero {
    position: relative;
    padding: 80px 0 48px;
    overflow: hidden;
    background-color: var(--bg);
  }

  .hero-bg-glow {
    position: absolute;
    top: -150px;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--accent) 0%, transparent 70%);
    opacity: 0.06;
    filter: blur(100px);
    pointer-events: none;
    animation: pulseGlow 8s ease-in-out infinite;
  }

  [data-theme="dark"] .hero-bg-glow {
    opacity: 0.08;
  }

  @keyframes pulseGlow {
    0%, 100% { transform: translateX(-50%) scale(1); opacity: 0.06; }
    50% { transform: translateX(-50%) scale(1.2); opacity: 0.10; }
  }

  .hero-center {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    padding: 6px 18px;
    font-size: 13px;
    font-weight: 500;
    border-radius: var(--radius-pill);
    background-color: var(--accent-light);
    color: var(--accent);
    margin-bottom: 20px;
  }

  .hero-title {
    font-size: 46px;
    font-weight: 700;
    line-height: 1.15;
    color: var(--text-primary);
    margin-bottom: 16px;
  }

  .hero-desc {
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-secondary);
    margin-bottom: 28px;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-bottom: 36px;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-stat-num {
    font-size: 24px;
    font-weight: 700;
    color: var(--accent);
  }

  .hero-stat-label {
    font-size: 12px;
    color: var(--text-muted);
  }

  .hero-stat-divider {
    width: 1px;
    height: 28px;
    background-color: var(--border);
  }

  .hero-orbit {
    position: relative;
    height: 320px;
    margin-top: 40px;
    z-index: 1;
  }

  .orbit-ring {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .glass-card {
    backdrop-filter: blur(14px) saturate(170%);
    -webkit-backdrop-filter: blur(14px) saturate(170%);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.28) 0%,
      rgba(255, 255, 255, 0.10) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.22);
    box-shadow:
      0 6px 28px rgba(0, 0, 0, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.25);
  }

  [data-theme="dark"] .glass-card {
    background: linear-gradient(
      135deg,
      rgba(139, 124, 246, 0.10) 0%,
      rgba(26, 25, 50, 0.35) 100%
    );
    border: 1px solid rgba(139, 124, 246, 0.14);
    box-shadow:
      0 6px 28px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.06),
      0 0 16px rgba(139, 124, 246, 0.05);
  }

  .hero-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 22px;
    border-radius: var(--radius-md);
    cursor: default;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.3s ease;
    will-change: transform;
    white-space: nowrap;
  }

  .orbit-ring.spinning .hero-card {
    transition: transform 0.15s linear, box-shadow 0.3s ease;
  }

  .hero-card:hover {
    box-shadow:
      0 12px 36px rgba(0, 0, 0, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.35),
      0 0 24px rgba(229, 176, 68, 0.12);
  }

  [data-theme="dark"] .hero-card:hover {
    box-shadow:
      0 12px 36px rgba(0, 0, 0, 0.45),
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 0 24px rgba(139, 124, 246, 0.2);
  }

  .hero-card-emoji {
    font-size: 24px;
    filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.08));
  }

  .hero-card-text {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
  }

  @media (max-width: 960px) {
    .hero-title { font-size: 34px; }
    .hero-orbit { height: 260px; }
    .hero-card { padding: 12px 18px; }
    .hero-card-emoji { font-size: 20px; }
    .hero-card-text { font-size: 13px; }
  }

  @media (max-width: 480px) {
    .hero { padding: 48px 0 32px; }
    .hero-title { font-size: 26px; }
    .hero-stats { gap: 16px; flex-wrap: wrap; }
    .hero-orbit { height: 200px; }
  }
</style>
